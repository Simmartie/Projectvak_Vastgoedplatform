```mermaid
erDiagram
    USERS {
      uuid id PK
      string name
      string email
      string role
      string phone
      datetime created_at
      datetime updated_at
    }

    PROPERTIES {
      uuid id PK
      uuid seller_id FK
      uuid agent_id FK
      string address
      string city
      string postal_code
      numeric price
      string type
      int rooms
      int bedrooms
      numeric area
      numeric plot_size
      int build_year
      string energy_label
      string status
      text description
      int views_count
      string phase
      numeric lat
      numeric lng
      datetime created_at
      datetime updated_at
    }

    PROPERTY_FEATURES {
      uuid id PK
      uuid property_id FK
      string feature_key
      string feature_value
    }

    PROPERTY_IMAGES {
      uuid id PK
      uuid property_id FK
      string url
      string alt_text
      int order_index
    }

    NEIGHBORHOODS {
      uuid id PK
      string name
      string city
      text description
    }

    PROPERTY_NEIGHBORHOOD {
      uuid property_id PK, FK
      uuid neighborhood_id PK, FK
    }

    NEIGHBORHOOD_ITEMS {
      uuid id PK
      uuid neighborhood_id FK
      string category
      string name
      text description
      int distance_meters
      numeric lat
      numeric lng
    }

    VISITS {
      uuid id PK
      uuid property_id FK
      uuid buyer_id FK
      datetime scheduled_at
      text feedback
      int rating
      datetime created_at
    }

    BIDS {
      uuid id PK
      uuid property_id FK
      uuid buyer_id FK
      numeric amount
      string status
      text comments
      datetime created_at
    }

    SESSIONS {
      uuid id PK
      uuid user_id FK
      string jwt_token
      datetime created_at
      datetime expires_at
    }

    CHAT_SESSIONS {
      uuid id PK
      uuid user_id FK
      uuid property_id FK
      string source
      datetime started_at
      datetime ended_at
    }

    CHAT_MESSAGES {
      uuid id PK
      uuid chat_session_id FK
      string sender_type
      text message_text
      string role
      datetime created_at
    }

    AI_PROMPTS {
      uuid id PK
      string name
      text prompt_text
      string model
      datetime created_at
      bool is_active
    }

    CHAT_MESSAGE_AI_META {
      uuid id PK
      uuid chat_message_id FK
      uuid ai_prompt_id FK
      string model
      int response_time_ms
      int tokens_input
      int tokens_output
    }

    PROPERTY_EMBEDDINGS {
      uuid id PK
      uuid property_id FK
      text embedding
      string model
      datetime created_at
    }

